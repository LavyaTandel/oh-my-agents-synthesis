{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oh My Agents Synthesis Plugin Configuration",
  "description": "Unified agent orchestration plugin for OpenCode - synthesizes oh-my-opencode-slim and oh-my-openagent with 5-model LOOM routing",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "preset": {
      "type": "string",
      "description": "Name of the preset to use (e.g. 'loom'). Overridden by OH_MY_AGENTS_PRESET env var."
    },
    "presets": {
      "type": "object",
      "description": "Named presets mapping agent roles to model configurations",
      "additionalProperties": {
        "$ref": "#/$defs/AgentOverrideConfig"
      }
    },
    "agents": {
      "type": "object",
      "description": "Per-agent override configuration",
      "additionalProperties": {
        "$ref": "#/$defs/AgentOverrideConfig"
      }
    },
    "disabled_agents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of agent names to disable"
    },
    "disabled_mcps": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["websearch", "context7", "grep_app"]
      },
      "description": "List of built-in MCPs to disable"
    },
    "disabled_skills": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of built-in skills to disable"
    },
    "disabled_hooks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of hooks to disable"
    },
    "multiplexer": {
      "$ref": "#/$defs/MultiplexerConfig"
    },
    "tmux": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "layout": {
          "type": "string",
          "enum": ["main-horizontal", "main-vertical", "tiled", "even-horizontal", "even-vertical"],
          "default": "main-vertical"
        },
        "main_pane_size": { "type": "number", "minimum": 20, "maximum": 80, "default": 60 }
      },
      "description": "Legacy tmux integration config (prefer 'multiplexer')"
    },
    "fallback": {
      "$ref": "#/$defs/FallbackConfig"
    },
    "council": {
      "$ref": "#/$defs/CouncilConfig"
    },
    "interview": {
      "$ref": "#/$defs/InterviewConfig"
    },
    "sessionManager": {
      "$ref": "#/$defs/SessionManagerConfig"
    },
    "todoContinuation": {
      "$ref": "#/$defs/TodoContinuationConfig"
    },
    "divoom": {
      "$ref": "#/$defs/DivoomConfig"
    },
    "websearch": {
      "$ref": "#/$defs/WebsearchConfig"
    },
    "autoUpdate": {
      "type": "boolean",
      "default": true,
      "description": "Enable automatic update checks"
    },
    "mcp_env_allowlist": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of allowed MCP environment variable names"
    },
    "hashline_edit": {
      "type": "boolean",
      "description": "Enable hashline_edit tool/hook integrations"
    },
    "new_task_system_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable new task system"
    },
    "default_run_agent": {
      "type": "string",
      "description": "Default agent for `oh-my-agents run` command"
    },
    "agent_order": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Preferred display order for agents"
    },
    "agent_definitions": {
      "type": "object",
      "properties": {
        "local": { "type": "array", "items": { "type": "string" } },
        "remote": { "type": "array", "items": { "type": "string" } }
      },
      "description": "Paths to external agent definition files"
    },
    "experimental": {
      "type": "object",
      "properties": {
        "safe_hook_creation": { "type": "boolean", "default": true },
        "autocontinue": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "ProviderModelId": {
      "type": "string",
      "pattern": "^[^/\\s]+/[^\\s]+$",
      "description": "Model ID in provider/model format (e.g. 'opencode/ring-2.6-1t-free')"
    },
    "AgentOverrideConfig": {
      "type": "object",
      "properties": {
        "model": {
          "oneOf": [
            { "$ref": "#/$defs/ProviderModelId" },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  { "$ref": "#/$defs/ProviderModelId" },
                  {
                    "type": "object",
                    "properties": {
                      "id": { "$ref": "#/$defs/ProviderModelId" },
                      "variant": { "type": "string" }
                    },
                    "required": ["id"]
                  }
                ]
              },
              "minItems": 1
            }
          ]
        },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "variant": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "mcps": { "type": "array", "items": { "type": "string" } },
        "prompt": { "type": "string", "minLength": 1 },
        "orchestratorPrompt": { "type": "string", "minLength": 1 },
        "options": { "type": "object" },
        "displayName": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "MultiplexerConfig": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["auto", "tmux", "zellij", "none"], "default": "none" },
        "layout": { "type": "string", "enum": ["main-horizontal", "main-vertical", "tiled", "even-horizontal", "even-vertical"], "default": "main-vertical" },
        "main_pane_size": { "type": "number", "minimum": 20, "maximum": 80, "default": 60 }
      }
    },
    "FallbackConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "chains": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },
    "CouncilConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "strategy": { "type": "string", "enum": ["first", "majority", "supermajority"], "default": "majority" },
        "minParticipants": { "type": "number", "minimum": 2, "maximum": 8, "default": 3 }
      }
    },
    "InterviewConfig": {
      "type": "object",
      "properties": {
        "maxQuestions": { "type": "number", "minimum": 1, "maximum": 10, "default": 2 },
        "outputFolder": { "type": "string", "minLength": 1, "default": "interview" },
        "autoOpenBrowser": { "type": "boolean", "default": true },
        "port": { "type": "number", "minimum": 0, "maximum": 65535, "default": 0 },
        "dashboard": { "type": "boolean", "default": false }
      }
    },
    "SessionManagerConfig": {
      "type": "object",
      "properties": {
        "maxSessionsPerAgent": { "type": "number", "minimum": 1, "maximum": 10, "default": 2 },
        "readContextMinLines": { "type": "number", "minimum": 0, "maximum": 1000, "default": 10 },
        "readContextMaxFiles": { "type": "number", "minimum": 0, "maximum": 50, "default": 8 }
      }
    },
    "TodoContinuationConfig": {
      "type": "object",
      "properties": {
        "maxContinuations": { "type": "number", "minimum": 1, "maximum": 50, "default": 5 },
        "cooldownMs": { "type": "number", "minimum": 0, "maximum": 30000, "default": 3000 },
        "autoEnable": { "type": "boolean", "default": false },
        "autoEnableThreshold": { "type": "number", "minimum": 1, "maximum": 20, "default": 4 }
      }
    },
    "DivoomConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "python": { "type": "string", "minLength": 1 },
        "script": { "type": "string", "minLength": 1 },
        "size": { "type": "number", "minimum": 1, "maximum": 1024, "default": 128 },
        "fps": { "type": "number", "minimum": 1, "maximum": 60, "default": 8 },
        "speed": { "type": "number", "minimum": 1, "maximum": 10000, "default": 125 },
        "maxFrames": { "type": "number", "minimum": 1, "maximum": 500, "default": 24 },
        "posterizeBits": { "type": "number", "minimum": 1, "maximum": 8, "default": 3 },
        "gifs": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } }
      }
    },
    "WebsearchConfig": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["exa", "tavily"], "default": "exa" }
      }
    }
  },
  "additionalProperties": false
}